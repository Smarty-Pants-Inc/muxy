#!/bin/bash
set -euo pipefail

APP_NAME="Muxy"
CLI_COMMAND="muxy"
URL_SCHEME="muxy"
BUNDLE_ID="com.muxy.app"
APP_SUPPORT_NAME="Muxy"
SOCKET_NAME="muxy.sock"
TARGET_DIR="${1:-}"

if [ -z "$TARGET_DIR" ]; then
    echo "Usage: ${CLI_COMMAND} <path>"
    echo "       ${CLI_COMMAND} ."
    exit 1
fi

case "$TARGET_DIR" in
    ~*) TARGET_DIR="${HOME}${TARGET_DIR:1}" ;;
    .)  TARGET_DIR="$(pwd)" ;;
    ..) TARGET_DIR="$(cd .. && pwd)" ;;
    *)  TARGET_DIR="$(cd "$TARGET_DIR" 2>/dev/null && pwd)" ;;
esac

if [ ! -d "$TARGET_DIR" ]; then
    echo "Error: $TARGET_DIR is not a valid directory"
    exit 1
fi

percent_encode() {
    if command -v python3 >/dev/null 2>&1; then
        python3 -c 'import sys, urllib.parse; sys.stdout.write(urllib.parse.quote(sys.argv[1], safe="/"))' "$1"
    elif command -v python >/dev/null 2>&1; then
        python -c 'import sys, urllib; sys.stdout.write(urllib.quote(sys.argv[1], safe="/"))' "$1"
    else
        printf '%s' "$1"
    fi
}

ENCODED_PATH="$(percent_encode "$TARGET_DIR")"
SOCKET="$HOME/Library/Application Support/${APP_SUPPORT_NAME}/${SOCKET_NAME}"

open "${URL_SCHEME}://open?path=${ENCODED_PATH}" 2>/dev/null \
    || open -b "$BUNDLE_ID" "$TARGET_DIR" 2>/dev/null \
    || {
        if [ -e "$SOCKET" ]; then
            printf 'open-project|%s\n' "$TARGET_DIR" | nc -U "$SOCKET" 2>/dev/null
        else
            echo "Error: ${APP_NAME} is not running and socket was not found: ${SOCKET}" >&2
            exit 1
        fi
    }
